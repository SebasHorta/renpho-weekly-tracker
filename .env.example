# Copy this file to .env and fill in your own values -- .env is gitignored,
# this file is not. Nothing here is real; every value is a placeholder.

# Your Renpho app login (fetcher.py).
RENPHO_EMAIL=your_email@example.com
RENPHO_PASSWORD=your_renpho_password

# For the automated weekly email (notify.py / weekly_check.py). EMAIL_APP_PASSWORD
# is a Google *app password* (myaccount.google.com/apppasswords, requires 2FA on
# the account), NOT your real Gmail password. See README.md's Setup section.
EMAIL_ADDRESS=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your16charapppassword

# Optional: who receives the weekly email. Defaults to EMAIL_ADDRESS (send to
# yourself) if omitted.
# EMAIL_TO=someone_else@example.com
